#include<bits/stdc++.h>

using namespace std;
int main()
{
    int h,w,n;
    cin>>h>>w>>n;

    vector<vector<int>> paper(h, vector<int>(w, 0));

    for (int i=0;i<n;i++)
    {
        int r,c,t,x;
        cin>>r>>c>>t>>x;
        for (int a=0;a<h;a++)
            for (int b=0;b<w;b++)
                if(abs(r-a)+abs(c-b)<=t)
                    paper[a][b]+=x;
    }

    for (int i=0;i<h;i++)
    {
        for (int j=0;j<w;j++)
            cout<<paper[i][j]<<" ";
        cout<<"\n";
    }
return 0;
}
